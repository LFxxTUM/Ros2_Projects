\@writefile{toc}{\contentsline {section}{\numberline {5.5}Das Two-Tower-Modell (Query--Key)}{14}{section.5.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Two-Tower-Modell: die Türme bleiben getrennt bis zum gemeinsamen Embedding-Raum -- genau diese Trennung \emph  {ist} die Architektur. Bei der Inferenz wird jedes Pixel-Embedding seinem nächsten Oberflächenpunkt-Embedding zugeordnet.}}{15}{figure.5.1}\protected@file@percent }
