\@writefile{toc}{\contentsline {section}{\numberline {5.7}Robuste Schätzung: RANSAC}{15}{section.5.7}\protected@file@percent }
\newlabel{sec:ransac}{{5.7}{15}{Robuste Schätzung: RANSAC}{section.5.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Koordinatensysteme der \texttt  {\small  PnP}-Posenschätzung: Ein Weltpunkt $\bm  {P}$ wird über die Außenorientierung $[\bm  {R},\bm  {t}]$ ins Kamerasystem $O_c$, dann über die Brennweite $f$ auf die normalisierte Bildebene und schließlich über die Intrinsik (Hauptpunkt $(u_0,v_0)$) in Pixelkoordinaten abgebildet. \texttt  {\small  PnP} löst die Umkehrung: aus Punkt-Pixel-Paaren und bekanntem $\bm  {K}$ die gesuchte Pose $[\bm  {R},\bm  {t}]$. Nach \blx@tocontentsinit {0}\cite {qiao2023pnp}.}}{16}{figure.caption.6}\protected@file@percent }
\newlabel{fig:pnp_algorithm}{{5.2}{16}{Koordinatensysteme der \code {PnP}-Posenschätzung: Ein Weltpunkt $\bm {P}$ wird über die Außenorientierung $[\bm {R},\bm {t}]$ ins Kamerasystem $O_c$, dann über die Brennweite $f$ auf die normalisierte Bildebene und schließlich über die Intrinsik (Hauptpunkt $(u_0,v_0)$) in Pixelkoordinaten abgebildet. \code {PnP} löst die Umkehrung: aus Punkt-Pixel-Paaren und bekanntem $\bm {K}$ die gesuchte Pose $[\bm {R},\bm {t}]$. Nach \cite {qiao2023pnp}}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.8}Registrierung: grob und fein}{16}{section.5.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.3}{\ignorespaces RANSAC am Beispiel der Geradenanpassung: Die durchgezogene Linie ist das Modell mit dem größten \emph  {Consensus Set} -- alle Punkte im hellen Band ($\pm \tau $) zählen als Inlier; die mit Kreuzen markierten Ausreißer werden verworfen. Die gestrichelte Linie ist eine zufällig gezogene Hypothese, die wegen zu weniger Inlier wieder verworfen wird. Prinzip nach \blx@tocontentsinit {0}\cite {raguram2008ransac}.}}{17}{figure.caption.7}\protected@file@percent }
\newlabel{fig:ransac_algorithm}{{5.3}{17}{RANSAC am Beispiel der Geradenanpassung: Die durchgezogene Linie ist das Modell mit dem größten \emph {Consensus Set} -- alle Punkte im hellen Band ($\pm \tau $) zählen als Inlier; die mit Kreuzen markierten Ausreißer werden verworfen. Die gestrichelte Linie ist eine zufällig gezogene Hypothese, die wegen zu weniger Inlier wieder verworfen wird. Prinzip nach \cite {raguram2008ransac}}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5.9}Punktwolken-Netze: PointNet und PointNet++}{17}{section.5.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces Eine ICP-Iteration: Zu jedem Punkt der Quellform (grün) wird der nächste Punkt der Zielform (rot) gesucht (gepunktete Korrespondenzen, $\bm  {x}^1_i=\arg \min _{\bm  {x}}\lVert f^0(\bm  {x})-\bm  {y}_i\rVert ^2$); anschließend liefert die Procrustes-Lösung die starre Transformation $f^1$, die die paarweise Distanz minimiert. Beide Schritte werden bis zur Konvergenz wiederholt. Nach \blx@tocontentsinit {0}\cite {ponsmoll2024icp}.}}{18}{figure.caption.8}\protected@file@percent }
\newlabel{fig:icp_algorithm}{{5.4}{18}{Eine ICP-Iteration: Zu jedem Punkt der Quellform (grün) wird der nächste Punkt der Zielform (rot) gesucht (gepunktete Korrespondenzen, $\bm {x}^1_i=\arg \min _{\bm {x}}\lVert f^0(\bm {x})-\bm {y}_i\rVert ^2$); anschließend liefert die Procrustes-Lösung die starre Transformation $f^1$, die die paarweise Distanz minimiert. Beide Schritte werden bis zur Konvergenz wiederholt. Nach \cite {ponsmoll2024icp}}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Semantische Segmentierung einer Außenszene im Vergleich: Gegenüber der Ground Truth (links) verschmiert \textbf  {PointNet} (Mitte) feine lokale Strukturen, weil das globale Max-Pooling die Nachbarschaftsinformation verliert. \textbf  {PointNet++} (rechts) gewinnt durch die hierarchische, lokale Merkmalsextraktion deutlich saubere Klassengrenzen zurück. Nach \blx@tocontentsinit {0}\cite {maral2023pointnet}.}}{18}{figure.caption.9}\protected@file@percent }
\newlabel{fig:pointnet}{{5.5}{18}{Semantische Segmentierung einer Außenszene im Vergleich: Gegenüber der Ground Truth (links) verschmiert \textbf {PointNet} (Mitte) feine lokale Strukturen, weil das globale Max-Pooling die Nachbarschaftsinformation verliert. \textbf {PointNet++} (rechts) gewinnt durch die hierarchische, lokale Merkmalsextraktion deutlich saubere Klassengrenzen zurück. Nach \cite {maral2023pointnet}}{figure.caption.9}{}}
